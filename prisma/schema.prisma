generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  nome                 String
  email                String              @unique
  senha                String
  role                 String              @default("VENDEDOR") // VENDEDOR | VENDEDOR_EXTERNO | VENDEDOR_HIBRIDO | ADMIN | DIRETOR | SUPERVISOR | SDR | POS_VENDA | FINANCEIRO | TECNICO
  ativo                Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  vendas               Venda[]
  dailyCommercials     DailyCommercial[]
  campanhasCriadas     Campanha[]          @relation("campanhasCriadas")
  // SDR relations
  registrosSDR         RegistroSDR[]       @relation("sdrRegistros")
  registrosVendedora   RegistroSDR[]       @relation("vendedoraRegistros")
  pagamentosSDR        RegistroSDR[]       @relation("pagoPor")
  pendenciasResolvidas PendenciaVinculo[]  @relation("resolvidoPor")
  // Pos Venda
  posVendaRegistros    PosVenda[]          @relation("posVendaOperador")
  // Ligacoes diarias SDR
  ligacoesSDR          LigacoesSDR[]       @relation("sdrLigacoes")
  // Calculadora
  simulacoes           SimulacaoVenda[]
  // Solicitações de exceção de margem (como supervisor)
  solicitacoesMargem   SolicitacaoMargem[] @relation("solicitacoesMargem")
  // Notificações
  notificacoes         Notificacao[]
}

model Venda {
  id                String @id @default(cuid())
  vendedorId        String
  vendedor          User   @relation(fields: [vendedorId], references: [id])
  cliente           String
  formaPagamento    String
  distribuidora     String
  valorVenda        Float
  kwp               Float
  custoEquipamentos Float
  geracaoKwh        Float
  over              Float
  margem            Float
  comissaoVenda     Float
  comissaoOver      Float
  comissaoTotal     Float

  // Campos de custo (visao diretor)
  quantidadePlacas     Int    @default(0)
  quantidadeInversores Int    @default(1)
  custoInstalacao      Float? // auto: (placas * custoPlaca) + (inversores * custoInversor)
  custoVisitaTecnica   Float? // padrao config, diretor pode editar
  custoCosern          Float? // padrao config, diretor pode editar
  custoTrtCrea         Float? // padrao config (R$65)
  custoEngenheiro      Float? // R$400 fixo por instalacao (engenheiro)
  custoMaterialCA      Float? // R$500 fixo (material CA)
  aliquotaImposto      Float? // padrao config (0.06 = 6%)

  // === Margem de instalacao (engenharia/Pedro) ===
  // Variaveis que definem o custo real da instalacao no campo
  metragemCaboPrevista       Int? // metros por perna (fase ou neutro)
  bitolaCabo                 String? // "6mm" | "10mm" — definida pela potencia do inversor + metragem
  inversorTrifasico          Boolean @default(false) // se sim, multiplica cabo por 4 em vez de 2
  cidadeInstalacao           String? // usada pra lookup de CustoDeslocamento
  custoInstalacaoEstimado    Float? // calculado no fechamento: cabo + eletroduto + fixos + deslocamento
  custoInstalacaoReal        Float? // preenchido pelo Pedro apos a instalacao concluida
  // VERDE  = dentro do padrao (real <= limite)
  // AMARELO = passou do padrao mas foi negociado/avisado
  // VERMELHO = passou e gerou perda nao recuperada
  statusMargemInstalacao     String?
  observacaoMargemInstalacao String? // contexto do que rolou se nao foi VERDE
  custoImposto               Float? // auto: aliquota * (valorVenda - custoEquipamentos)
  percentualComissaoOverride Float? // null = usa padrao da config (2.5%). Diretor pode alterar por venda
  comissaoVendedorCusto      Float? // copia do comissaoTotal para P&L
  lucroLiquido               Float?
  margemLucroLiquido         Float? // lucroLiquido / valorVenda

  // Exceção de margem (max 2/mes por vendedor)
  excecao             Boolean @default(false)
  // Venda atipica / excecao operacional (ex: pagamento a vista declarado, usina demo).
  // Fica FORA dos indicadores de performance comercial e da margem media da diretoria —
  // distorce a media. NAO afeta comissao nem o calculo da propria venda; so a agregacao.
  atipica             Boolean @default(false)
  // Venda bloqueada pra edicao (ex: excecao com economia manual que o recalculo
  // do app sobrescreveria). Quando true, o PUT rejeita qualquer alteracao —
  // so o DIRETOR pode destravar (enviar bloqueada=false).
  bloqueada           Boolean @default(false)
  // Controle de pagamento separado
  comissaoVendaPaga   Boolean @default(false)
  comissaoOverPaga    Boolean @default(false)
  // Histórico de alterações (JSON array)
  historicoAlteracoes String?

  // Orcamento PDF (base64, uploaded pelo vendedor ao fechar venda)
  orcamentoUrl String?

  dataConversao           DateTime
  fonte                   String
  // Origem da venda (relevante para VENDEDOR_HIBRIDO):
  // INBOUND = lead da empresa (Meta Ads/SDR), aplica faixa progressiva normal
  // EXTERNA = captacao propria do vendedor (porta a porta), comissao over flat 50%
  tipoVenda               String              @default("INBOUND") // INBOUND | EXTERNA
  status                  String              @default("AGUARDANDO") // AGUARDANDO | APROVADO | PAGO
  // Status do contrato (independente do pagamento de comissao):
  // COMPLETO    = fechado com empresa E banco, aprovado, venda finalizada
  // A_FINALIZAR = so assinou com a empresa; falta resolver burocracia
  //               (troca de titularidade, aprovacao de banco, etc.)
  // Default COMPLETO: vendas antigas e o caso comum ja entram como fechadas.
  statusContrato          String              @default("COMPLETO") // COMPLETO | A_FINALIZAR
  dataFinalizacaoContrato DateTime? // quando passou de A_FINALIZAR -> COMPLETO
  mesReferencia           String // formato: "2026-01" para agrupar por mês
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  // SDR relations
  registrosSDR            RegistroSDR[]
  pendenciaVinculo        PendenciaVinculo?
  // Pos Venda
  posVenda                PosVenda?
  // Setor Tecnico
  setorTecnico            SetorTecnico?
  // Solicitações de exceção de margem pendentes
  solicitacoesMargem      SolicitacaoMargem[]
  // Notificações
  notificacoes            Notificacao[]

  // Índices de performance (filtros/ordenação mais quentes do app)
  @@index([mesReferencia, vendedorId]) // dashboards mensais + por vendedor
  @@index([vendedorId]) // lista do próprio vendedor (todo período) / joins
  @@index([dataConversao]) // filtros por intervalo de data + orderBy
}

// Solicitação de ajuste de margem criada por supervisor, aprovada pelo diretor
model SolicitacaoMargem {
  id                    String   @id @default(cuid())
  vendaId               String
  venda                 Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  clienteNome           String
  vendedorNome          String
  margemAtual           Float
  custoEquipAtual       Float
  novaMargem            Float
  novoCustoEquipamentos Float
  solicitanteId         String
  solicitante           User     @relation("solicitacoesMargem", fields: [solicitanteId], references: [id])
  status                String   @default("AGUARDANDO") // AGUARDANDO | APROVADO | REJEITADO
  observacao            String?
  createdAt             DateTime @default(now())
}

model Configuracao {
  id                      String @id @default("config_principal")
  fatorMultiplicador      Float  @default(1.8)
  fatorGeracao            Float  @default(136)
  percentualComissaoVenda Float  @default(0.025)
  volumeMinimoComissao    Float  @default(60000)

  // Metas (ranking)
  metaVendasMes    Float @default(120000) // Meta mensal de vendas por vendedor (R$ — receita)
  metaVendasQtdMes Int   @default(8) // Meta mensal de QUANTIDADE de vendas por vendedor (dashboard "meta batida")
  metaMargemMedia  Float @default(1.8) // Meta de margem media por vendedor

  // Meta de receita mensal da empresa (soma das metas individuais) — usada
  // como base para calcular comissao do SUPERVISOR
  metaReceitaMensal Float @default(360000) // R$ 360k = 3 vendedores x R$ 120k

  // Custo fixo mensal da empresa (aluguel, salarios, estrutura) — usado para
  // calcular o RESULTADO REAL e o PONTO DE EQUILIBRIO na visao da diretoria.
  // Nao entra no lucroLiquido por venda (que e margem de contribuicao); entra
  // so na agregacao mensal. Default R$ 40k (custo fixo ~R$33.9k + folga).
  custoFixoMensal Float @default(40000)

  // Comissao do SUPERVISOR: percentual sobre receita mensal total da empresa,
  // aplicado em faixas conforme % da meta atingida
  percentualSupervisorAte80    Float @default(0.0) // < 80% da meta: 0%
  percentualSupervisor80a100   Float @default(0.008) // 80-99% da meta: 0,8%
  percentualSupervisorAcima100 Float @default(0.01) // >= 100% da meta: 1%

  // Margem de instalacao (engenharia)
  limiteCustoInstalacao Float @default(998) // R$ — base do VERDE (Pedro mediu 23 de 34 dentro disso)
  metragemCaboPadrao    Int   @default(15) // m por perna — abaixo disso e VERDE garantido
  metragemCaboTolerada  Int   @default(20) // m por perna — entre padrao e tolerada e amarelo

  // Custos padrao (visao diretor)
  custoPlacaInstalacao     Float @default(70) // R$70 por placa
  custoInversorInstalacao  Float @default(250) // R$250 por inversor
  custoVisitaTecnicaPadrao Float @default(120) // R$120 por venda
  custoCosernPadrao        Float @default(70) // 2 x R$35
  custoTrtCreaPadrao       Float @default(65) // R$65 fixo
  custoEngenheiroPadrao    Float @default(400) // R$400 por instalacao (engenheiro)
  custoMaterialCAPadrao    Float @default(500) // R$500 material CA
  aliquotaImpostoPadrao    Float @default(0.06) // 6%
}

// Performance: Diario de Trafego (um registro por dia, empresa toda)
model DailyTraffic {
  id                     String   @id @default(cuid())
  data                   String   @unique // formato "YYYY-MM-DD"
  pessoasAlcancadas      Int      @default(0)
  totalLeads             Int      @default(0)
  valorInvestidoVendas   Float    @default(0)
  valorInvestidoBranding Float    @default(0)
  valorGasto             Float    @default(0)
  syncSource             String   @default("manual") // "manual" | "meta_ads" | "mixed"
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Performance: Diario Comercial (um registro por dia por vendedor)
model DailyCommercial {
  id               String   @id @default(cuid())
  data             String // formato "YYYY-MM-DD"
  vendedorId       String
  vendedor         User     @relation(fields: [vendedorId], references: [id])
  atendidos        Int      @default(0)
  mql              Int      @default(0)
  reunioes         Int      @default(0)
  propostas        Int      @default(0)
  fechados         Int      @default(0)
  valorEmVendas    Float    @default(0)
  leadsDescartados Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([data, vendedorId])
}

model FaixaComissao {
  id             String  @id @default(cuid())
  ordem          Int
  volumeMinimo   Float
  volumeMaximo   Float? // null = sem limite
  percentualOver Float
  ativa          Boolean @default(true)
}

// SDR: Registro de acompanhamento de leads até reunião/venda
model RegistroSDR {
  id                     String   @id @default(cuid())
  sdrId                  String
  sdr                    User     @relation("sdrRegistros", fields: [sdrId], references: [id])
  dataRegistro           String // "YYYY-MM-DD" dia do lancamento
  // Quem originou a oportunidade:
  // SDR      = prospeccao da SDR (Samara/Joao Paulo) — paga comissao SDR normal
  // VENDEDOR = auto-prospeccao do proprio vendedor (ligou/qualificou/agendou) —
  //            conta a eficiencia mas NAO paga comissao SDR (sdrId == vendedoraId)
  origemRegistro         String   @default("SDR") // "SDR" | "VENDEDOR"
  nomeCliente            String
  telefone               String? // E.164 (55+DDD+numero) — chave de match CAPI Meta / ChatClean
  vendedoraId            String
  vendedora              User     @relation("vendedoraRegistros", fields: [vendedoraId], references: [id])
  dataReuniao            String // "YYYY-MM-DD"
  compareceu             Boolean  @default(false)
  motivoNaoCompareceu    String? // dropdown padronizado (apenas se nao compareceu)
  motivoFinalizacao      String? // motivo de finalizacao (CPF negada, sumiu, etc)
  consideracoes          String? // texto livre
  statusLead             String   @default("AGENDADO") // "AGENDADO" | "COMPARECEU" | "VENDIDO" | "FINALIZADO"
  // Forecast (editavel pelo vendedor)
  valorForecast          Float? // valor estimado que o vendedor acredita fechar
  estagioOportunidade    String   @default("REUNIAO") // "REUNIAO"|"PROPOSTA"|"NEGOCIACAO"|"FECHADA"
  probabilidade          Int      @default(50) // 0-100%
  dataFechamentoEsperado String? // "YYYY-MM-DD"
  // Vinculo automatico com venda
  vendaVinculadaId       String?
  vendaVinculada         Venda?   @relation(fields: [vendaVinculadaId], references: [id])
  dataVendaVinculada     String? // "YYYY-MM-DD" auto-set quando vinculado
  // Comissao (100% automatica)
  comissaoReuniao        Float    @default(0) // R$20 se compareceu
  comissaoVenda          Float    @default(0) // R$20 se venda vinculada
  comissaoTotal          Float    @default(0) // reuniao + venda (0/20/40)
  // Pagamento
  statusPagamento        String   @default("PENDENTE") // "PENDENTE" | "PAGO"
  dataPagamento          String?
  pagoPorId              String?
  pagoPor                User?    @relation("pagoPor", fields: [pagoPorId], references: [id])
  // Imagem anexada (conta de luz ou documento do cliente, base64)
  imagemUrl              String?
  // Nota privada do supervisor (visivel apenas para ADMIN e DIRETOR)
  notaAdmin              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Índices de performance (filtros mais quentes do módulo SDR)
  @@index([sdrId]) // registros do SDR + pagamento/extrato
  @@index([vendedoraId]) // pipeline/forecast por vendedora
  @@index([vendaVinculadaId]) // vínculo registro↔venda
  @@index([dataRegistro]) // recorte por dia/mês de lançamento
  @@index([dataReuniao]) // agenda/recorte por data de reunião
}

// SDR: Ligacoes diarias (input manual da SDR)
model LigacoesSDR {
  id         String   @id @default(cuid())
  sdrId      String
  sdr        User     @relation("sdrLigacoes", fields: [sdrId], references: [id])
  data       String // "YYYY-MM-DD"
  quantidade Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sdrId, data])
}

// Metricas SDR manuais (override do supervisor para agilizar analises)
model MetricasSDROverride {
  id                String   @id @default(cuid())
  periodo           String   @unique // "dia:2026-03-02" | "semana:2026-02-23" | "mes:2026-03"
  ligacoes          Int?
  reunioesAgendadas Int?
  cpfNegado         Int?
  desqualificados   Int?
  noShow            Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// SDR: Pendencias de vinculo (vendas com match ambiguo ou sem match)
model PendenciaVinculo {
  id                  String   @id @default(cuid())
  vendaId             String   @unique
  venda               Venda    @relation(fields: [vendaId], references: [id])
  status              String   @default("PENDENTE") // "PENDENTE" | "RESOLVIDO" | "SEM_SDR"
  registroEscolhidoId String?
  resolvidoPorId      String?
  resolvidoPor        User?    @relation("resolvidoPor", fields: [resolvidoPorId], references: [id])
  dataResolucao       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Pos Venda: acompanhamento pos-instalacao do cliente solar
model PosVenda {
  id                  String   @id @default(cuid())
  operadorId          String
  operador            User     @relation("posVendaOperador", fields: [operadorId], references: [id])
  // Dados do cliente
  nomeCliente         String
  telefone            String?
  codigoLocalizador   String? // tag curta de 4 digitos, compartilhada com o card de engenharia
  // Vinculo opcional com venda do sistema
  vendaId             String?  @unique
  venda               Venda?   @relation(fields: [vendaId], references: [id])
  // Etapa atual do funil pos-venda
  etapa               String   @default("TRAMITES")
  // "TRAMITES" | "AGUARDANDO_MATERIAL" | "VISITA_TECNICA" | "AGUARDANDO_VISTORIA" | "CADASTRAR_APP" | "ACOMPANHAMENTO_30" | "CLIENTE_FINALIZADO" | "MANUTENCOES"
  // Etiquetas manuais paralelas a etapa (JSON array de keys de ETIQUETAS em
  // src/lib/etiquetas.ts): FECHADO | TRAMITACAO | DEBITO. Multi-select.
  etiquetas           String?
  // Acompanhamento
  ultimaAcao          String?
  proximaAcao         String?
  observacoes         String?
  ultimoContato       String? // "YYYY-MM-DD"
  proximoContato      String? // "YYYY-MM-DD"
  // Anexos (JSON array: [{nome, url, data}])
  anexos              String?
  // Historico de acoes anteriores (JSON array: [{data, acao}]) — legado
  historicoAcoes      String?
  // Tarefas (JSON array: [{id, descricao, status, criadoEm}]) status: PENDENTE|FAZENDO|FINALIZADO
  tarefas             String?
  // Anotacoes livres do operador pos-venda
  anotacoes           String?
  // Previsoes de datas (operador preenche)
  previsaoMaterial    String? // "YYYY-MM-DD"
  previsaoInstalacao  String? // "YYYY-MM-DD"
  // Controle de conferencia pelo supervisor
  conferido           Boolean  @default(false)
  dataConferido       String? // "YYYY-MM-DD"
  // Checklist de etapas da supervisao (JSON: [{key, label, concluido}])
  checklistSupervisao String?
  // Prazo de finalizacao definido pelo sistema (2 dias apos criacao)
  prazoFinalizacao    String? // "YYYY-MM-DD"
  // Controle
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ativo, etapa])
  @@index([proximoContato])
}

// Setor Tecnico: acompanhamento do projeto tecnico apos venda
model SetorTecnico {
  id                  String   @id @default(cuid())
  nomeCliente         String
  telefone            String?
  email               String?
  codigoLocalizador   String? // tag curta de 4 digitos, compartilhada com o card de pos-venda
  // Vinculo com venda do sistema
  vendaId             String?  @unique
  venda               Venda?   @relation(fields: [vendaId], references: [id])
  vendedorNome        String?
  // Trilho PROJETO (administrativo, ate o projeto ser aprovado).
  // Valores: NOVO_PROJETO, CONSULTAR_CARGA, AUMENTO_CARGA, EMITIR_TRT,
  //   LIBERADO_ENVIO, PROJETO_ENVIADO, PROJETO_APROVADO
  // Mantido com o nome `etapa` por compatibilidade com o schema antigo
  // (db push em prod nao suporta rename sem perda de dado).
  etapa               String   @default("NOVO_PROJETO")
  // Trilho INSTALACAO (operacional, do agendamento ate a rede ligada).
  // Valores: AGENDAR_VISITA, VISITA_AGENDADA, VISITA_FEITA, AGUARDANDO_MATERIAL,
  //   MATERIAL_ENTREGUE, INSTALACAO_AGENDADA, MATERIAL_COMPRADO, INSTALACAO_CONCLUIDA,
  //   SOLICITADO_VISTORIA, REDE_LIGADA (rotulada "Usina Ligada")
  // Card nasce com AGENDAR_VISITA e aparece em ambas as abas desde o inicio.
  etapaInstalacao     String   @default("AGENDAR_VISITA")
  // Acompanhamento
  observacoes         String?
  ultimaAcao          String?
  proximaAcao         String?
  // Historico de acoes anteriores (JSON array: [{data, acao}])
  historicoAcoes      String?
  // Anexos (JSON array: [{nome, url, data}])
  anexos              String?
  // Comentarios do engenheiro (JSON array: [{id, autor, texto, criadoEm}])
  comentarios         String?
  // Validacao de visita tecnica (engenheiro marca quando visita aconteceu — Yuri
  // usa pra liberar pagamento da visita sem ter que perguntar no grupo)
  visitaValidada      Boolean  @default(false)
  // Bloqueio atual (impede avanco de etapa). Key de MOTIVOS_BLOQUEIO em
  // src/lib/setor-tecnico.ts ou null.
  bloqueioStatus      String?
  // Checklist de documentos exigidos antes de virar etapa INSTALACAO
  // (JSON: [{key, label, concluido}])
  checklistDocumentos String?
  // Etiquetas manuais paralelas a etapa (JSON array de keys de ETIQUETAS em
  // src/lib/etiquetas.ts): FECHADO | TRAMITACAO | DEBITO. Multi-select.
  etiquetas           String?
  // === Custo do material CA (engenharia/Pedro) ===
  // Custo real do material que o Pedro lanca no card ao chegar em MATERIAL_COMPRADO.
  // Alimenta a pagina Margem de Instalacao (o "caixao de material"). So TECNICO edita.
  custoMaterialReal   Float?
  // Classificacao MANUAL da margem do material: VERDE | AMARELO | VERMELHO
  statusMaterial      String?
  // Datas-chave da fase instalacao (preenchidas pelo engenheiro)
  dataVisita          String? // "YYYY-MM-DD"
  dataInstalacao      String? // "YYYY-MM-DD"
  dataRedeLigada      String? // "YYYY-MM-DD"
  dataVistoria        String? // "YYYY-MM-DD" — vistoria da concessionaria (edicao exclusiva engenheiro)
  // Controle
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ativo, etapa])
  @@index([ativo, etapaInstalacao])
  @@index([createdAt])
}

// Calculadora: Histórico de simulações de venda por vendedor
model SimulacaoVenda {
  id                   String   @id @default(cuid())
  vendedorId           String
  vendedor             User     @relation(fields: [vendedorId], references: [id])
  // Inputs
  valorVenda           Float
  custoEquipamentos    Float
  kwp                  Float    @default(0)
  quantidadePlacas     Int      @default(0)
  quantidadeInversores Int      @default(1)
  ehExcecao            Boolean  @default(false)
  // Resultados calculados
  margemVendedor       Float
  over                 Float
  lucroLiquido         Float
  margemEmpresa        Float
  custoTotal           Float
  vendaSaudavel        Boolean
  mesReferencia        String // "2026-01" para filtrar por mês
  createdAt            DateTime @default(now())

  @@index([vendedorId, mesReferencia]) // histórico de simulações do vendedor no mês
}

// Notificações do sistema (nova venda, comissão paga, etc.)
model Notificacao {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tipo      String // "NOVA_VENDA" | "COMISSAO_PAGA"
  mensagem  String
  lida      Boolean  @default(false)
  vendaId   String?
  venda     Venda?   @relation(fields: [vendaId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, lida]) // sininho de notificações carrega em toda página
}

// ============================================================
// REVENUE ANALYTICS — Sync de dados externos
// ============================================================

// Meta Ads: snapshot diario por campanha/adset
model MetaAdsCampaign {
  id            String   @id @default(cuid())
  data          String // "YYYY-MM-DD"
  campaignId    String
  campaignName  String
  adsetId       String   @default("account_level")
  adsetName     String   @default("Total da Conta")
  spend         Float    @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  cpm           Float    @default(0)
  leads         Int      @default(0)
  messages      Int      @default(0)
  costPerResult Float    @default(0)
  synced_at     DateTime @default(now())

  @@unique([data, campaignId, adsetId])
}

// Gronner CRM: leads sincronizados com scoring ICP
model GronnerLead {
  id               String   @id @default(cuid())
  gronnerId        String   @unique
  nome             String
  telefone         String?
  origem           String?
  icpScore         Int      @default(0)
  icpClasse        String? // "quente_a" | "quente_b" | "morno" | "frio"
  status           String?
  etapa            String?
  preVendedor      String?
  vendedor         String?
  valorProposta    Float?
  gronnerCreatedAt String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  synced_at        DateTime @default(now())
}

// Nibo: registros financeiros (contas a receber e pagar)
model NiboRecord {
  id             String   @id @default(cuid())
  niboId         String   @unique
  tipo           String // "receber" | "pagar"
  descricao      String
  categoria      String?
  valor          Float
  dataVencimento String
  dataPagamento  String?
  status         String // "aberto" | "pago" | "vencido"
  contato        String?
  synced_at      DateTime @default(now())
}

// Instagram: metricas diarias da conta
model InstagramDaily {
  id              String   @id @default(cuid())
  data            String   @unique
  seguidores      Int      @default(0)
  novosSeguidores Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  profileViews    Int      @default(0)
  websiteClicks   Int      @default(0)
  postsPublicados Int      @default(0)
  stories         Int      @default(0)
  reels           Int      @default(0)
  synced_at       DateTime @default(now())
}

// Instagram: metricas por post
model InstagramPost {
  id          String   @id @default(cuid())
  igPostId    String   @unique
  tipo        String // "IMAGE" | "VIDEO" | "CAROUSEL" | "REEL" | "STORY"
  caption     String?
  publishedAt DateTime
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  engagement  Float    @default(0)
  synced_at   DateTime @default(now())
}

// YouTube: metricas diarias do canal
model YouTubeDaily {
  id               String   @id @default(cuid())
  data             String   @unique
  inscritos        Int      @default(0)
  novosInscritos   Int      @default(0)
  views            Int      @default(0)
  watchTimeMin     Float    @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  videosPublicados Int      @default(0)
  synced_at        DateTime @default(now())
}

// YouTube: metricas por video
model YouTubeVideo {
  id              String   @id @default(cuid())
  ytVideoId       String   @unique
  titulo          String
  publishedAt     DateTime
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  watchTimeMin    Float    @default(0)
  avgViewDuration Float    @default(0)
  ctr             Float    @default(0)
  synced_at       DateTime @default(now())
}

// Tabela de precos unitarios de materiais de instalacao (admin/diretor edita).
// Usada pra calcular custoInstalacaoEstimado na hora do fechamento da venda.
model PrecoMaterial {
  id        String   @id @default(cuid())
  chave     String   @unique // "CABO_6MM", "CABO_10MM", "ELETRODUTO_MEIA", "ELETRODUTO_UMA", "DPS", "DISJUNTOR", "QUADRO"
  label     String
  precoUnit Float
  unidade   String // "m" (por metro) | "un" (por unidade)
  ativo     Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Tabela de custos de deslocamento por cidade. Cidades fora da lista somam zero.
model CustoDeslocamento {
  id        String   @id @default(cuid())
  cidade    String   @unique
  valor     Float
  updatedAt DateTime @updatedAt
}

// Limite operacional de custo de instalacao por venda — usado pra classificar
// status VERDE/AMARELO/VERMELHO. Pedro ajusta conforme o real do mes.
// (Esse limite vive em Configuracao porque e parametro unico do sistema; nao
// gera nova tabela)

// Campanhas: metas de vendas criadas por Diretor/Supervisor
model Campanha {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  tipo        String // "VALOR" (meta em R$) | "QUANTIDADE" (meta em qtd vendas)
  escopo      String // "TIME" (meta coletiva) | "INDIVIDUAL" (meta por vendedor)
  meta        Float // valor da meta (R$ ou quantidade)
  dataInicio  String // "YYYY-MM-DD"
  dataFim     String // "YYYY-MM-DD"
  ativa       Boolean  @default(true)
  criadoPorId String
  criadoPor   User     @relation("campanhasCriadas", fields: [criadoPorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
